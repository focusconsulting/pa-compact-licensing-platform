# Default recipe: show available commands
default:
    @just --list

app_name := "pa-compact-api"
image_tag := if `git rev-parse --is-inside-work-tree 2>/dev/null || true` == "true" { `git rev-parse HEAD` } else { "unknown-dev." + `date -u '+%Y%m%d.%H%M%S'` }
open_cmd := if os() == "macos" { "open" } else { "xdg-open" }

# Install dependencies
install:
    uv sync

# Start local Postgres and Redis containers
infra: infra-down
    docker compose -p pa-compact up -d

# Stop local infrastructure containers
infra-down:
    docker compose -p pa-compact down -v

# Run the API with hot reload. Override env file with: just dev env-file=.env.dev
dev env-file=".env":
    uv run uvicorn licensing_api.__main__:app --reload --env-file {{ env-file }}

# Run tests (pass additional args with: just test -k test_name)
test *args:
    uv run --env-file .env pytest {{ args }}

# Run tests with coverage report
test-coverage *args:
    uv run coverage run --branch --source=licensing_api -m pytest {{ args }}
    uv run coverage report

# Open HTML coverage report in browser
test-coverage-report:
    uv run coverage html --directory .coverage_report
    {{ open_cmd }} .coverage_report/index.html

# Run all linting (ruff + pyright)
lint: lint-ruff typecheck

# Run ruff linter and format check
lint-ruff:
    uv run ruff check licensing_api tests
    uv run ruff format --check licensing_api tests

# Run pyright type checker
typecheck:
    uv run pyright licensing_api

# Format code with ruff
format:
    uv run ruff check --fix licensing_api tests
    uv run ruff format licensing_api tests

# Build production Docker image
build:
    docker build \
        --tag {{ app_name }}:latest \
        --tag {{ app_name }}:{{ image_tag }} \
        --target app
